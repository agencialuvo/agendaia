# ── Base de datos ──────────────────────────────────────────────
DATABASE_URL="postgresql://velia:velia@localhost:5433/velia_crm?schema=public"

# ── Redis (colas de recordatorios, retargeting, WebSockets) ────
REDIS_URL="redis://localhost:6379"

# ── Autenticación ────────────────────────────────────────────────
JWT_SECRET="cambiar-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="8h"

# Clave que solo tu empresa conoce — se exige para eliminar cualquier usuario Admin Master
# (de plataforma o de una clínica). Cámbiala por un valor largo y guárdalo aparte, no en git.
CLAVE_MAESTRA_ELIMINACION="cambiar-por-una-clave-larga-solo-para-tu-empresa"

# Usuario inicial de plataforma que crea `npm run prisma:seed` — es el único Admin Master
# con el que puedes entrar la primera vez para crear al resto de usuarios.
ADMIN_MASTER_EMAIL="admin@agendaia.com"
ADMIN_MASTER_PASSWORD="cambiar-esta-contrasena"

# ── Anthropic (motor conversacional de IA) ──────────────────────
ANTHROPIC_API_KEY=""
IA_MODEL="claude-opus-4-8"   # cambiar a claude-sonnet-5 si se prioriza costo sobre calidad en volumen alto

# ── Meta (Lead Ads + WhatsApp Business Platform) ────────────────
META_APP_ID=""
META_APP_SECRET=""
META_VERIFY_TOKEN="token-de-verificacion-webhook"
META_PAGE_ACCESS_TOKEN=""

# "simulado" registra los mensajes en el log sin enviarlos de verdad — úsalo mientras no haya
# acceso real a Meta Cloud API / un BSP. Cuando llegue el acceso: meta_cloud_api | twilio | 360dialog
WHATSAPP_PROVIDER="simulado"
WHATSAPP_PHONE_NUMBER_ID=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""

# ── Google Calendar (Service Account — un solo calendario de la clínica) ──
# client_email y private_key vienen del JSON que descarga Google Cloud al crear
# la clave de la cuenta de servicio. El calendario de la clínica debe compartirse
# con ese client_email (permiso "Hacer cambios en los eventos").
GOOGLE_CALENDAR_CLIENT_EMAIL=""
GOOGLE_CALENDAR_PRIVATE_KEY=""
GOOGLE_CALENDAR_ID=""
DURACION_CITA_MINUTOS=60

# ── App ──────────────────────────────────────────────────────────
API_PORT=3000
WEB_URL="http://localhost:5173"
NODE_ENV="development"

# ── Reportes públicos ────────────────────────────────────────────
REPORTE_TOKEN_SECRET="otro-secreto-para-firmar-links-publicos-de-reportes"